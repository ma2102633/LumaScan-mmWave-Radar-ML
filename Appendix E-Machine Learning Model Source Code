def build_dataset(tumor_root, no_tumor_root, max_files=None):
    X, y, sessions, meta = [], [], [], []
    session_idx = 0

    for label, root, label_name, colour in [
        (1, tumor_root,    'TUMOR',    PINK),
        (0, no_tumor_root, 'NO-TUMOR', TEAL),
    ]:
        for sess_name, bin_files in discover_sessions(root):
            if max_files:
                bin_files = bin_files[:max_files]
            sess_feats = []
            for bf in tqdm(bin_files, desc=f'{sess_name[-28:]:>28}', leave=False):
                try:
                    f = extract_features(load_bin_file(bf))
                    if np.all(np.isfinite(f)):
                        sess_feats.append(f)
                    else:
                        print(f'  [SKIP NaN] {os.path.basename(bf)}')
                except Exception as e:
                    print(f'  [WARN] {os.path.basename(bf)}: {e}')
            if sess_feats:
                n = len(sess_feats)
                X.extend(sess_feats)
                y.extend([label] * n)
                sessions.extend([session_idx] * n)
                meta.append(dict(idx=session_idx, name=sess_name,
                                 label=label_name, colour=colour, n=n))
                session_idx += 1
                print(f'  ✓ [{label_name}] {sess_name[-45:]:>45}  {n} frames')

    return np.array(X), np.array(y), np.array(sessions), meta


