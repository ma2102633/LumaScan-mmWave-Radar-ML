def compute_range_profile(data):
    """Mean range FFT magnitude over chirps. Returns (NUM_RX, RANGE_BINS)."""
    return np.abs(np.fft.rfft(data, axis=-1)).mean(axis=0)

def compute_range_doppler(data):
    """2D Range-Doppler map averaged over RX. Returns (RANGE_BINS, NUM_CHIRPS)."""
    rng = np.abs(np.fft.rfft(data, axis=-1))
    dop = np.abs(np.fft.fftshift(np.fft.fft(rng, axis=0), axes=0))
    return dop.mean(axis=1).T

