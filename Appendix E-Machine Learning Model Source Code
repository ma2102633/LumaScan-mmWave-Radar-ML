def load_bin_file(filepath):
    """
    Load TI DCA1000 .bin → shaped array (NUM_CHIRPS, NUM_RX, SPC).
    Format: int16, 4 RX real-sampled interleaved [RX0,RX1,RX2,RX3,...]
    Short files are zero-padded; footer bytes are stripped.
    """
    if not os.path.isfile(filepath):
        raise ValueError(f'Not a file: {filepath}')
    if os.path.getsize(filepath) < 8:
        raise ValueError(f'File too small')

    raw = np.atleast_1d(np.fromfile(filepath, dtype=np.int16))

    if len(raw) >= EXPECTED_INT16:
        raw = raw[:EXPECTED_INT16]
    else:
        padded = np.zeros(EXPECTED_INT16, dtype=np.int16)
        padded[:len(raw)] = raw
        raw = padded

    return raw.reshape(NUM_CHIRPS, NUM_RX, SPC).astype(np.float32)


