def loso_cv(X, y, sessions, meta, clf_name, clf):
    """Leave-One-Session-Out CV. Returns results dict."""
    all_true, all_pred, all_prob = [], [], []
    per_session = []

    for sid in np.unique(sessions):
        test_mask  = sessions == sid
        train_mask = ~test_mask

        pipe = Pipeline([('scaler', StandardScaler()), ('clf', clf)])
        pipe.fit(X[train_mask], y[train_mask])
        preds = pipe.predict(X[test_mask])

        try:
            probs = pipe.predict_proba(X[test_mask])[:, 1]
        except AttributeError:
            df = pipe.decision_function(X[test_mask])
            probs = (df - df.min()) / (df.max() - df.min() + 1e-9)

        sess_info = next(m for m in meta if m['idx'] == sid)
        per_session.append(dict(
            session  = sess_info['name'],
            label    = sess_info['label'],
            colour   = sess_info['colour'],
            n_test   = int(test_mask.sum()),
            accuracy = float(accuracy_score(y[test_mask], preds)),
            # Store for session-level aggregation
            true_label = int(y[test_mask][0]),
            pred_hard  = int(np.bincount(preds).argmax()),                 # majority vote
            pred_soft  = int(probs.mean() >= 0.5),                         # soft vote
            prob_mean  = float(probs.mean()),
        ))
        all_true.extend(y[test_mask])
        all_pred.extend(preds)
        all_prob.extend(probs)

    all_true = np.array(all_true)
    all_pred = np.array(all_pred)
    all_prob = np.array(all_prob)

    try:
        auc = roc_auc_score(all_true, all_prob)
        fpr, tpr, _ = roc_curve(all_true, all_prob)
    except Exception:
        auc, fpr, tpr = float('nan'), None, None

    # ── Session-level metrics ─────────────────────────────────────────────
    s_true      = [p['true_label'] for p in per_session]
    s_hard      = [p['pred_hard']  for p in per_session]
    s_soft      = [p['pred_soft']  for p in per_session]
    s_probs     = [p['prob_mean']  for p in per_session]
    sess_acc_hard = float(accuracy_score(s_true, s_hard))
    sess_acc_soft = float(accuracy_score(s_true, s_soft))
    try:
        sess_auc = roc_auc_score(s_true, s_probs)
    except Exception:
        sess_auc = float('nan')

    return dict(
        clf_name        = clf_name,
        per_session     = per_session,
        # Frame-level
        frame_acc       = float(accuracy_score(all_true, all_pred)),
        frame_auc       = auc,
        fpr=fpr, tpr=tpr,
        all_true=all_true, all_pred=all_pred,
        cm_frame        = confusion_matrix(all_true, all_pred),
        report_frame    = classification_report(all_true, all_pred,
                              target_names=['No-Tumor','Tumor']),
        # Session-level
        sess_acc_hard   = sess_acc_hard,
        sess_acc_soft   = sess_acc_soft,
        sess_auc        = sess_auc,
        s_true          = s_true,
        s_hard          = s_hard,
        s_soft          = s_soft,
        s_probs         = s_probs,
        cm_sess_hard    = confusion_matrix(s_true, s_hard),
        cm_sess_soft    = confusion_matrix(s_true, s_soft),
    )


