def build_visual_model(input_shape=(50, 2048)):
image_input = Input(shape=input_shape, name="image_input")
x = Conv1D(filters=32, kernel_size=3, activation='relu', padding='same')(image_input)
x = GlobalAveragePooling1D()(x)
x = Dense(32, activation='relu')(x)
out = Dense(1, activation='sigmoid')(x)
model = Model(image_input, out, name="Visual_CNN")
model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
return model
##E.2 Gene Feature Encoder (Dense Network)
def build_genomic_model(input_shape=(20318,)):
gene_input = Input(shape=input_shape, name="gene_input")
x = Dense(256, activation='relu')(gene_input)
x = Dropout(0.5)(x)
x = Dense(64, activation='relu')(x)
out = Dense(1, activation='sigmoid')(x)
model = Model(gene_input, out, name="Genomic_DNN")
model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
return model
##E.3 Early Fusion Model
def build_early_fusion_model(img_shape=(50, 2048), gene_shape=(20318,)):
image_input = Input(shape=img_shape, name="image_input")
gene_input = Input(shape=gene_shape, name="gene_input")
xi = Conv1D(filters=32, kernel_size=3, activation='relu', padding='same')(image_input)
xi = GlobalAveragePooling1D()(xi)
xg = Dense(32, activation='relu')(gene_input)
fused = concatenate([xi, xg])
x = Dense(32, activation='relu')(fused)
out = Dense(1, activation='sigmoid')(x)
model = Model([image_input, gene_input], out, name="EarlyFusion")
model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
return model
##E.4 Hyper Gene -Image Fusion Model
def build_hyper_gene_to_image_model(img_shape=(50, 2048), gene_shape=(20318,)):
"""
Gene -> Image: gene produces a modulation vector applied to image features (FiLM-like).
"""
image_input = Input(shape=img_shape, name="image_input")
gene_input = Input(shape=gene_shape, name="gene_input")
# Gene modulation vector
gene_mod = Dense(32, activation='sigmoid')(gene_input) # (B, 32)
gene_mod = Lambda(lambda t: tf.expand_dims(t, axis=1))(gene_mod) # (B, 1, 32)
# Image features
xi = Conv1D(32, 3, padding='same', activation='relu')(image_input) # (B, T, 32)
# Apply modulation
x_mod = Lambda(lambda z: z[0] * z[1])([xi, gene_mod]) # (B, T, 32)
x = GlobalAveragePooling1D()(x_mod)
x = Dense(32, activation='relu')(x)
out = Dense(1, activation='sigmoid')(x)
model = Model([image_input, gene_input], out, name="Hyper_Gene2Image")
model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
return model
##E.5 Hyper Image -Gene Fusion Model
def build_hyper_image_to_gene_model(img_shape=(50, 2048), gene_shape=(20318,)):
"""
Image -> Gene: image produces a modulation vector applied to gene features.
"""
image_input = Input(shape=img_shape, name="image_input")
gene_input = Input(shape=gene_shape, name="gene_input")
xi = Conv1D(32, 3, padding='same', activation='relu')(image_input)
xi = GlobalAveragePooling1D()(xi) # (B, 32)
img_mod = Dense(32, activation='sigmoid')(xi) # (B, 32)
xg = Dense(64, activation='relu')(gene_input)
xg = Dense(32, activation='relu')(xg) # (B, 32)
x_mod = Lambda(lambda z: z[0] * z[1])([xg, img_mod]) # (B, 32)
x = Dense(32, activation='relu')(x_mod)
out = Dense(1, activation='sigmoid')(x)
model = Model([image_input, gene_input], out, name="Hyper_Image2Gene")
model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
return model
