Step 4 · Enhanced Feature Extraction

PEAK_WIN = 10   # bins around peak for neighbourhood features

def extract_features(data):
    """
    Extract a 68-element feature vector from one radar frame.

    Parameters
    ----------
    data : np.ndarray, float32, shape (NUM_CHIRPS, NUM_RX, SPC)

    Returns
    -------
    features : np.ndarray, float32, shape (68,)
    """
    # ── Range FFT (real signal → rfft) ───────────────────────────────────
    range_fft = np.abs(np.fft.rfft(data, axis=-1))   # (chirps, rx, range_bins)
    mean_rp   = range_fft.mean(axis=0)[:, 1:]        # skip DC → (rx, range_bins-1)
    rb        = mean_rp.shape[1]                      # 608

    feats = []

    # ── A. Range profile stats per RX (7 × 4 = 28) ───────────────────────
    for rx in range(NUM_RX):
        p = mean_rp[rx]
        feats += [
            float(p.mean()),
            float(p.std()),
            float(p.max()),
            float(p.max() / (p.mean() + 1e-9)),
            float(np.argmax(p) / rb),
            float(skew(p)),
            float(kurtosis(p)),
        ]

    # ── B. Doppler stats at peak range bin per RX (4 × 4 = 16) ───────────
    peak_bin = int(np.argmax(mean_rp.mean(axis=0))) + 1   # +1 for DC skip
    doppler  = np.abs(np.fft.fft(
        range_fft[:, :, peak_bin], axis=0
    ))[:NUM_CHIRPS // 2]   # (chirps//2, rx)

    for rx in range(NUM_RX):
        d = doppler[:, rx]
        feats += [
            float(d.mean()),
            float(d.std()),
            float(d.max()),
            float(np.argmax(d) / len(d)),
        ]

    # ── C. Chirp-energy variation (5) ─────────────────────────────────────
    # Energy per chirp averaged over RX and samples
    chirp_energy = (data ** 2).mean(axis=(1, 2))   # (NUM_CHIRPS,)
    feats += [
        float(chirp_energy.mean()),
        float(chirp_energy.std()),
        float(chirp_energy.std() / (chirp_energy.mean() + 1e-9)),   # CV
        float(skew(chirp_energy)),
        float(kurtosis(chirp_energy)),
    ]

    # ── D. Slow-time phase features at peak bin per RX (3 × 4 = 12) ───────
    # Use Hilbert transform on the peak-bin slow-time signal (across chirps)
    for rx in range(NUM_RX):
        slow_time = range_fft[:, rx, peak_bin].astype(np.float64)
        try:
            analytic   = hilbert(slow_time)
            phase      = np.unwrap(np.angle(analytic))
            phase_diff = np.diff(phase)
            feats += [
                float(phase.std()),
                float(phase_diff.mean()),
                float(phase_diff.std()),
            ]
        except Exception:
            feats += [0.0, 0.0, 0.0]

    # ── E. Inter-RX coherence (1) ──────────────────────────────────────────
    # Mean pairwise Pearson correlation of mean range profiles across RX
    corrs = []
    for i in range(NUM_RX):
        for j in range(i + 1, NUM_RX):
            c = float(np.corrcoef(mean_rp[i], mean_rp[j])[0, 1])
            corrs.append(c if np.isfinite(c) else 0.0)
    feats.append(float(np.mean(corrs)))

    # ── F. Peak neighbourhood shape (3) ───────────────────────────────────
    avg_rp  = mean_rp.mean(axis=0)   # (rb,)
    p_start = max(0, peak_bin - 1 - PEAK_WIN)
    p_end   = min(rb, peak_bin - 1 + PEAK_WIN)
    window  = avg_rp[p_start:p_end]
    feats += [
        float(window.mean()),
        float(window.std()),
        float(skew(window)) if len(window) > 2 else 0.0,
    ]

    # ── G. Energy + peak bin + entropy (3) ────────────────────────────────
    energy   = float((data ** 2).mean())
    psd      = avg_rp ** 2
    psd_norm = psd / (psd.sum() + 1e-9)
    entropy  = float(-np.sum(psd_norm * np.log(psd_norm + 1e-9)))
    feats += [
        float(np.log1p(energy)),
        float(peak_bin / RANGE_BINS),
        entropy,
    ]

    return np.array(feats, dtype=np.float32)   # (68,)


